    <footer>
      <div class="p-3 border-t bg-muted/40">
        <div class="flex items-center gap-2 mb-2">
          <div class="bg-primary/10 text-primary rounded-full size-8 flex items-center justify-center font-bold text-xs uppercase">
            <%= user ? user.username.substring(0, 2) : 'U' %>
          </div>
