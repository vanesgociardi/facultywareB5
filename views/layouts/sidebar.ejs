<main id="content" class="flex-1 flex flex-col min-w-0 min-h-screen">
  <header class="bg-background sticky inset-x-0 top-0 isolate flex shrink-0 items-center gap-2 border-b z-10 h-14 px-6 justify-between">
    <div class="flex items-center gap-2">
      <button
        type="button"
        onclick="document.dispatchEvent(new CustomEvent('basecoat:sidebar'))"
        class="btn-outline btn-sm lg:hidden"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="18" y2="18"/></svg>
      </button>
      <h1 class="text-md font-semibold text-foreground"><%= title %></h1>
    </div>
    
    <div class="flex items-center gap-2">
      <span class="text-xs text-muted-foreground">Sesi: <strong><%= user ? user.username : '' %></strong></span>
    </div>
  </header>

  <div class="flex-1 p-6 overflow-y-auto">
    <!-- Flash Messages -->
    <% if (success) { %>
      <div class="mb-4 bg-emerald-500/10 border border-emerald-500/30 text-emerald-600 dark:text-emerald-400 p-3 rounded-md text-sm flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        <span><%= success %></span>
      </div>
    <% } %>

    <% if (error) { %>
      <div class="mb-4 bg-rose-500/10 border border-rose-500/30 text-rose-600 dark:text-rose-400 p-3 rounded-md text-sm flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" x2="12" y1="8" y2="12"/><line x1="12" x2="12.01" y1="16" y2="16"/></svg>
        <span><%= error %></span>
      </div>
    <% } %>

    <% if (warning) { %>
      <div class="mb-4 bg-amber-500/10 border border-amber-500/30 text-amber-600 dark:text-amber-400 p-3 rounded-md text-sm flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><line x1="12" x2="12" y1="9" y2="13"/><line x1="12" x2="12.01" y1="17" y2="17"/></svg>
        <span><%= warning %></span>
      </div>
    <% } %>
