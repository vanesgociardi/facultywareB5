<%- include('../layouts/header') %>
<%- include('../layouts/sidebar') %>
<% const query = typeof locals.query !== 'undefined' ? locals.query : { search: '', status: '' } %>

<div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-6">
  <div>
    <h2 class="text-xl font-bold tracking-tight text-foreground">Permohonan Perjalanan Dinas</h2>
    <p class="text-sm text-muted-foreground">Kelola permohonan, jadwal, dokumen, dan laporan perjalanan dinas Anda.</p>
  </div>
  <div class="flex flex-wrap gap-2">
    <a href="/pegawai/travels/create" class="btn-primary flex items-center gap-1.5">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
      <span>Tambah Permohonan</span>
    </a>
    <a href="/pegawai/export/travels" class="btn-outline flex items-center gap-1.5">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
      <span>Export Excel</span>
    </a>
  </div>
</div>

<!-- Import Excel Card -->
<div data-slot="card" class="rounded-xl border bg-card text-card-foreground shadow-xs p-6 mb-6">
  <h3 class="font-semibold text-sm mb-2">Import Permohonan dari Excel</h3>
  <form action="/pegawai/import/travels" method="POST" enctype="multipart/form-data" class="flex flex-col md:flex-row items-end gap-3">
    <div class="grid w-full max-w-sm gap-1.5">
      <label for="importFile" class="text-xs text-muted-foreground">Pilih File Excel (.xlsx)</label>
      <input type="file" name="importFile" id="importFile" accept=".xlsx" required class="flex h-9 w-full rounded-md border border-input bg-transparent px-3 py-1 text-xs shadow-xs file:border-0 file:bg-transparent file:text-xs file:font-medium text-foreground" />
    </div>
    <button type="submit" class="btn-secondary h-9">
      <span>Import</span>
    </button>
    <a href="/assets/templates/template-travel-import.xlsx" class="text-xs text-primary underline mb-2 ml-auto" style="display:none;">Download Template</a>
  </form>
</div>

<!-- Table Card -->
<div id="travel-table-card" data-slot="card" class="rounded-xl border bg-card text-card-foreground shadow-xs overflow-hidden">
  <!-- Search & Filter Bar -->
  <div class="p-4 border-b bg-muted/20">
    <form method="GET" action="/pegawai/travels" class="flex flex-col sm:flex-row gap-3 w-full" hx-boost="true" hx-target="#travel-table-card" hx-select="#travel-table-card">
      <div class="relative flex-1">
        <span class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none text-muted-foreground">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-search"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
        </span>
        <input 
          type="text" 
          name="search" 
          id="search-input"
          value="<%= query.search %>" 
          placeholder="Cari berdasarkan tujuan, maksud, atau nomor..." 
          class="input pl-9 w-full h-9 text-xs"
        />
      </div>
      <div class="w-full sm:w-48">
        <select name="status" id="status-filter" class="select w-full h-9 text-xs" onchange="this.form.requestSubmit()">
          <option value="">Semua Status</option>
          <option value="draft" <%= query.status === 'draft' ? 'selected' : '' %>>Draft</option>
          <option value="pending" <%= query.status === 'pending' ? 'selected' : '' %>>Pending</option>
          <option value="approved" <%= query.status === 'approved' ? 'selected' : '' %>>Approved</option>
          <option value="rejected" <%= query.status === 'rejected' ? 'selected' : '' %>>Rejected</option>
          <option value="completed" <%= query.status === 'completed' ? 'selected' : '' %>>Completed</option>
        </select>
      </div>
      <div class="flex gap-2">
        <button type="submit" id="search-submit" class="btn-primary h-9 text-xs px-4">Cari</button>
        <% if (query.search || query.status) { %>
          <a href="/pegawai/travels" id="search-reset" class="btn-outline h-9 text-xs px-4 flex items-center justify-center" hx-boost="true" hx-target="#travel-table-card" hx-select="#travel-table-card">Reset</a>
        <% } %>
      </div>
    </form>
  </div>
  <div class="overflow-x-auto">
    <table class="w-full text-sm text-left">
      <thead class="bg-muted/40 border-b text-muted-foreground text-xs uppercase font-medium">
        <tr>
          <th class="px-6 py-3">No. Permohonan</th>
          <th class="px-6 py-3">Tujuan</th>
          <th class="px-6 py-3">Maksud Perjalanan</th>
          <th class="px-6 py-3">Tanggal Berangkat</th>
          <th class="px-6 py-3">Tanggal Pulang</th>
          <th class="px-6 py-3">Status</th>
          <th class="px-6 py-3 text-right">Aksi</th>
        </tr>
      </thead>
      <tbody>
        <% if (travels.length === 0) { %>
          <tr>
            <td colspan="7" class="text-center py-8 text-muted-foreground">Belum ada data permohonan perjalanan dinas. Silakan tambah permohonan baru.</td>
          </tr>
        <% } else { %>
          <% travels.forEach(t => { %>
            <tr class="border-b hover:bg-muted/30 transition-colors">
              <td class="px-6 py-4 font-semibold text-foreground"><%= t.request_number %></td>
              <td class="px-6 py-4"><%= t.destination %></td>
              <td class="px-6 py-4 truncate max-w-[200px]"><%= t.purpose %></td>
              <td class="px-6 py-4 text-xs"><%= new Date(t.start_date).toLocaleDateString('id-ID', {day: 'numeric', month: 'short', year: 'numeric'}) %></td>
              <td class="px-6 py-4 text-xs"><%= new Date(t.end_date).toLocaleDateString('id-ID', {day: 'numeric', month: 'short', year: 'numeric'}) %></td>
              <td class="px-6 py-4">
                <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-semibold badge-<%= t.status %>">
                  <%= t.status %>
                </span>
              </td>
              <td class="px-6 py-4 text-right space-x-1 whitespace-nowrap">
                <a href="/pegawai/travels/detail/<%= t.id %>" class="btn-outline btn-xs" data-tooltip="Detail & Kelola">Detail</a>
                
                <% if (t.status === 'draft' || t.status === 'pending') { %>
                  <a href="/pegawai/travels/edit/<%= t.id %>" class="btn-outline btn-xs text-blue-600 dark:text-blue-400">Edit</a>
                  <a href="/pegawai/travels/delete/<%= t.id %>" onclick="return confirm('Apakah Anda yakin ingin menghapus permohonan ini?')" class="btn-destructive btn-xs">Hapus</a>
                <% } %>
                
                <% if (t.status === 'draft') { %>
                  <a href="/pegawai/travels/submit/<%= t.id %>" onclick="return confirm('Ajukan permohonan ini untuk disetujui pimpinan?')" class="btn-primary btn-xs">Submit</a>
                <% } %>
              </td>
            </tr>
          <% }) %>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<%- include('../layouts/footer') %>
