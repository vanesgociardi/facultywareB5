<%- include('../layouts/header') %>
<%- include('../layouts/sidebar') %>

<div class="mb-6 flex items-center justify-between">
  <div>
    <h2 class="text-xl font-bold tracking-tight text-foreground"><%= travel ? 'Edit' : 'Tambah' %> Permohonan Perjalanan Dinas</h2>
    <p class="text-sm text-muted-foreground">Isi data permohonan dengan lengkap dan benar.</p>
  </div>
  <a href="/pegawai/travels" class="btn-outline btn-sm flex items-center gap-1">
    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" x2="5" y1="12" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
    <span>Kembali</span>
  </a>
</div>

<div data-slot="card" class="rounded-xl border bg-card text-card-foreground shadow-xs p-6 max-w-2xl mx-auto">
  <form action="<%= travel ? '/pegawai/travels/edit/' + travel.id : '/pegawai/travels/create' %>" method="POST" enctype="multipart/form-data" class="space-y-6">
    
    <!-- Purpose / Maksud Perjalanan -->
    <div role="group" class="flex flex-col gap-2">
      <label for="purpose" class="text-sm font-medium">Maksud / Keperluan Perjalanan Dinas <span class="text-destructive">*</span></label>
      <textarea id="purpose" name="purpose" rows="4" required class="flex min-h-[80px] w-full rounded-md border border-input bg-transparent px-3 py-2 text-sm shadow-xs placeholder:text-muted-foreground outline-none focus-visible:border-ring focus-visible:ring-[3px] focus-visible:ring-ring/50"><%= travel ? travel.purpose : '' %></textarea>
    </div>

    <!-- Destination -->
    <div role="group" class="flex flex-col gap-2">
      <label for="destination" class="text-sm font-medium">Tujuan / Destinasi <span class="text-destructive">*</span></label>
      <input type="text" id="destination" name="destination" value="<%= travel ? travel.destination : '' %>" placeholder="Contoh: Bandung, Jawa Barat" required class="flex h-9 w-full rounded-md border border-input bg-transparent px-3 py-1 text-sm shadow-xs placeholder:text-muted-foreground outline-none focus-visible:border-ring focus-visible:ring-[3px] focus-visible:ring-ring/50" />
    </div>

    <!-- Dates Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <!-- Start Date -->
      <div role="group" class="flex flex-col gap-2">
        <label for="start_date" class="text-sm font-medium">Tanggal Mulai <span class="text-destructive">*</span></label>
        <% 
          let defaultStart = '';
          if (travel && travel.start_date) {
            defaultStart = new Date(travel.start_date).toISOString().slice(0, 10);
          }
        %>
        <input type="date" id="start_date" name="start_date" value="<%= defaultStart %>" required class="flex h-9 w-full rounded-md border border-input bg-transparent px-3 py-1 text-sm shadow-xs outline-none focus-visible:border-ring focus-visible:ring-[3px] focus-visible:ring-ring/50" />
      </div>

      <!-- End Date -->
      <div role="group" class="flex flex-col gap-2">
        <label for="end_date" class="text-sm font-medium">Tanggal Selesai <span class="text-destructive">*</span></label>
        <% 
          let defaultEnd = '';
          if (travel && travel.end_date) {
            defaultEnd = new Date(travel.end_date).toISOString().slice(0, 10);
          }
        %>
        <input type="date" id="end_date" name="end_date" value="<%= defaultEnd %>" required class="flex h-9 w-full rounded-md border border-input bg-transparent px-3 py-1 text-sm shadow-xs outline-none focus-visible:border-ring focus-visible:ring-[3px] focus-visible:ring-ring/50" />
      </div>
    </div>

    <!-- Upload Surat Undangan (Optional) -->
    <div role="group" class="flex flex-col gap-2">
      <label for="invitation" class="text-sm font-medium">Surat Undangan / Dokumen Pendukung (Opsional)</label>
      <input type="file" id="invitation" name="invitation" accept=".pdf,.doc,.docx,.jpg,.jpeg,.png" class="flex h-9 w-full rounded-md border border-input bg-transparent px-3 py-1 text-sm file:border-0 file:bg-transparent file:text-sm file:font-medium text-foreground outline-none" />
      <% if (travel && travel.invitation_file) { %>
        <p class="text-xs text-muted-foreground mt-1">File saat ini: <a href="<%= travel.invitation_file %>" target="_blank" class="text-primary underline">Lihat File</a></p>
      <% } %>
      <p class="text-[10px] text-muted-foreground">Format yang diizinkan: PDF, DOC, DOCX, JPG, JPEG, PNG.</p>
    </div>

    <!-- Submit buttons -->
    <div class="flex items-center gap-2 pt-4 border-t">
      <button type="submit" class="btn-primary">
        <span>Simpan Draft</span>
      </button>
      <a href="/pegawai/travels" class="btn-outline">
        <span>Batal</span>
      </a>
    </div>

  </form>
</div>

<%- include('../layouts/footer') %>
