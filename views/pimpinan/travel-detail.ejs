<%- include('../layouts/header') %>
<%- include('../layouts/sidebar') %>

<div class="mb-6 flex items-center justify-between">
  <div>
    <h2 class="text-xl font-bold tracking-tight text-foreground">Proses Persetujuan Perjalanan Dinas</h2>
    <p class="text-sm text-muted-foreground">Verifikasi data perjalanan dinas dan berikan keputusan persetujuan.</p>
  </div>
  <a href="/pimpinan/travels" class="btn-outline btn-sm flex items-center gap-1">
    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" x2="5" y1="12" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
    <span>Kembali</span>
  </a>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-6">
  
  <!-- Left Column: Travel details -->
  <div class="lg:col-span-2 space-y-6">
    
    <!-- Core details -->
    <div data-slot="card" class="rounded-xl border bg-card text-card-foreground shadow-xs p-6">
      <div class="flex items-center justify-between border-b pb-4 mb-4">
        <h3 class="font-semibold text-lg">Informasi Perjalanan</h3>
        <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold badge-<%= travel.status %>">
          <%= travel.status.toUpperCase() %>
        </span>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <p class="text-xs text-muted-foreground">Nomor Surat Tugas</p>
          <p class="text-sm font-semibold text-foreground"><%= travel.request_number %></p>
        </div>
        <div>
          <p class="text-xs text-muted-foreground">Diajukan Oleh</p>
          <p class="text-sm font-semibold text-foreground"><%= travel.submitter_name %> (ID: <%= travel.submitted_by_id %>)</p>
        </div>
        <div>
          <p class="text-xs text-muted-foreground">Tujuan / Destinasi</p>
          <p class="text-sm font-semibold text-foreground"><%= travel.destination %></p>
        </div>
        <div>
          <p class="text-xs text-muted-foreground">Tanggal Pelaksanaan</p>
          <p class="text-sm text-foreground">
            <%= new Date(travel.start_date).toLocaleDateString('id-ID', {weekday: 'long', day: 'numeric', month: 'long', year: 'numeric'}) %> s/d<br/>
            <%= new Date(travel.end_date).toLocaleDateString('id-ID', {weekday: 'long', day: 'numeric', month: 'long', year: 'numeric'}) %>
          </p>
        </div>
        <div>
          <p class="text-xs text-muted-foreground">Surat Undangan</p>
          <% if (travel.invitation_file) { %>
            <a href="<%= travel.invitation_file %>" target="_blank" class="text-sm text-primary underline font-medium">Buka File Surat Undangan</a>
          <% } else { %>
            <p class="text-sm text-muted-foreground">-</p>
          <% } %>
        </div>
        <div class="md:col-span-2">
          <p class="text-xs text-muted-foreground">Keperluan / Maksud Tugas</p>
          <p class="text-sm text-foreground whitespace-pre-line"><%= travel.purpose %></p>
        </div>
      </div>
    </div>

    <!-- Itineraries -->
    <div data-slot="card" class="rounded-xl border bg-card text-card-foreground shadow-xs p-6">
      <h3 class="font-semibold text-lg mb-4 border-b pb-2">Jadwal Perjalanan (Itinerary)</h3>
      <div class="overflow-x-auto">
        <table class="w-full text-sm text-left">
          <thead class="bg-muted/40 text-xs text-muted-foreground uppercase font-medium">
            <tr class="border-b">
              <th class="py-2 px-3">Tanggal</th>
              <th class="py-2 px-3">Lokasi</th>
              <th class="py-2 px-3">Aktivitas</th>
              <th class="py-2 px-3">Keterangan</th>
            </tr>
          </thead>
          <tbody>
            <% if (itineraries.length === 0) { %>
              <tr>
                <td colspan="4" class="text-center py-4 text-muted-foreground text-xs">Belum ada rincian jadwal kegiatan.</td>
              </tr>
            <% } else { %>
              <% itineraries.forEach(i => { %>
                <tr class="border-b hover:bg-muted/20">
                  <td class="py-3 px-3 text-xs whitespace-nowrap"><%= new Date(i.date).toLocaleDateString('id-ID', {day: 'numeric', month: 'short', year: 'numeric'}) %></td>
                  <td class="py-3 px-3"><%= i.location %></td>
                  <td class="py-3 px-3 font-medium"><%= i.activity %></td>
                  <td class="py-3 px-3 text-xs"><%= i.description || '-' %></td>
                </tr>
              <% }) %>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Members -->
    <div data-slot="card" class="rounded-xl border bg-card text-card-foreground shadow-xs p-6">
      <h3 class="font-semibold text-lg mb-4 border-b pb-2">Anggota Perjalanan & Laporan Ringkas</h3>
      <div class="overflow-x-auto">
        <table class="w-full text-sm text-left">
          <thead class="bg-muted/40 text-xs text-muted-foreground uppercase font-medium">
            <tr class="border-b">
              <th class="py-2 px-3">Nama Anggota</th>
              <th class="py-2 px-3">Peran / Role</th>
              <th class="py-2 px-3">Laporan Ringkas</th>
              <th class="py-2 px-3">Tanggal Lapor</th>
              <th class="py-2 px-3">Lampiran</th>
            </tr>
          </thead>
          <tbody>
            <% if (members.length === 0) { %>
              <tr>
                <td colspan="5" class="text-center py-4 text-muted-foreground text-xs">Belum ada anggota perjalanan.</td>
              </tr>
            <% } else { %>
              <% members.forEach(m => { %>
                <tr class="border-b hover:bg-muted/20">
                  <td class="py-3 px-3 font-medium"><%= m.name %></td>
                  <td class="py-3 px-3 text-xs"><%= m.role %></td>
                  <td class="py-3 px-3 text-xs truncate max-w-[150px]"><%= m.summary || '-' %></td>
                  <td class="py-3 px-3 text-xs"><%= m.report_date ? new Date(m.report_date).toLocaleDateString('id-ID') : '-' %></td>
                  <td class="py-3 px-3 text-xs">
                    <% if (m.attachment) { %>
                      <a href="<%= m.attachment %>" target="_blank" class="text-primary underline">Lihat</a>
                    <% } else { %>
                      -
                    <% } %>
                  </td>
                </tr>
              <% }) %>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Expenses -->
    <div data-slot="card" class="rounded-xl border bg-card text-card-foreground shadow-xs p-6">
      <h3 class="font-semibold text-lg mb-4 border-b pb-2">Klaim Reimbursement Terkait</h3>
      <div class="overflow-x-auto">
        <table class="w-full text-sm text-left">
          <thead class="bg-muted/40 text-xs text-muted-foreground uppercase font-medium">
            <tr class="border-b">
              <th class="py-2 px-3">Komponen Biaya</th>
              <th class="py-2 px-3">Jumlah</th>
              <th class="py-2 px-3">Keterangan</th>
              <th class="py-2 px-3">Bukti Nota</th>
              <th class="py-2 px-3">Status</th>
            </tr>
          </thead>
          <tbody>
            <% if (expenses.length === 0) { %>
              <tr>
                <td colspan="5" class="text-center py-4 text-muted-foreground text-xs">Belum ada pengajuan reimburse.</td>
              </tr>
            <% } else { %>
              <% expenses.forEach(e => { %>
                <tr class="border-b hover:bg-muted/20">
                  <td class="py-3 px-3 font-medium"><%= e.component_name %> (<%= e.component_code %>)</td>
                  <td class="py-3 px-3">Rp <%= Number(e.amount).toLocaleString('id-ID') %></td>
                  <td class="py-3 px-3 text-xs"><%= e.description || '-' %></td>
                  <td class="py-3 px-3 text-xs">
                    <% if (e.receipt_file) { %>
                      <a href="<%= e.receipt_file %>" target="_blank" class="text-primary underline font-medium">Lihat Nota</a>
                    <% } else { %>
                      -
                    <% } %>
                  </td>
                  <td class="py-3 px-3">
                    <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-semibold badge-<%= e.status %>">
                      <%= e.status %>
                    </span>
                  </td>
                </tr>
              <% }) %>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>

  </div>

  <!-- Right Column: Approvals / Decisions -->
  <div class="space-y-6">
    
    <!-- Decisions Panel -->
    <% if (travel.status === 'pending') { %>
      <div data-slot="card" class="rounded-xl border bg-card text-card-foreground shadow-xs p-6 border-amber-500/50 bg-amber-500/5">
        <h3 class="font-semibold text-lg mb-4 text-amber-800 dark:text-amber-300">Keputusan Pimpinan</h3>
        
        <form id="approvalForm" method="POST" class="space-y-4">
          <div class="flex flex-col gap-1.5">
            <label for="notes" class="text-sm font-medium">Catatan / Alasan Keputusan <span class="text-destructive">*</span></label>
            <textarea id="notes" name="notes" rows="4" placeholder="Tulis catatan persetujuan atau alasan penolakan di sini..." class="flex w-full rounded-md border border-input bg-background px-3 py-2 text-sm shadow-xs outline-none focus-visible:border-ring focus-visible:ring-[3px] focus-visible:ring-ring/50"></textarea>
          </div>
          
          <div class="flex flex-col gap-2 pt-2">
            <button type="submit" onclick="submitDecision('/pimpinan/travels/approve/<%= travel.id %>', 'approve')" class="btn-primary w-full justify-center">
              Setujui (Approve)
            </button>
            <button type="submit" onclick="submitDecision('/pimpinan/travels/reject/<%= travel.id %>', 'reject')" class="btn-destructive w-full justify-center">
              Tolak (Reject)
            </button>
          </div>
        </form>

        <script>
          function submitDecision(actionUrl, type) {
            const form = document.getElementById('approvalForm');
            form.action = actionUrl;
            
            if (type === 'reject') {
              const notes = document.getElementById('notes').value;
              if (!notes || notes.trim() === '') {
                alert('Anda wajib menuliskan alasan penolakan pada kolom Catatan!');
                event.preventDefault();
                return false;
              }
            }
          }
        </script>
      </div>
    <% } else { %>
      <div data-slot="card" class="rounded-xl border bg-card text-card-foreground shadow-xs p-6">
        <h3 class="font-semibold text-lg mb-2">Status Peninjauan</h3>
        <p class="text-xs text-muted-foreground mb-4">Permohonan ini telah diproses.</p>
        <div class="space-y-2">
          <p class="text-xs">Diproses Oleh: <strong><%= travel.approved_by || '-' %></strong></p>
          <p class="text-xs">Tanggal: <strong><%= travel.approved_at ? new Date(travel.approved_at).toLocaleString('id-ID') : '-' %></strong></p>
        </div>
      </div>
    <% } %>

    <!-- Documents -->
    <div data-slot="card" class="rounded-xl border bg-card text-card-foreground shadow-xs p-6">
      <h3 class="font-semibold text-lg mb-4 border-b pb-2">Dokumen Berkas</h3>
      <ul class="space-y-3">
        <% if (documents.length === 0) { %>
          <li class="text-xs text-muted-foreground text-center py-2">Belum ada berkas pendukung terunggah.</li>
        <% } else { %>
          <% documents.forEach(d => { %>
            <li class="p-2 rounded-md bg-muted/40 border border-input/30 text-xs">
              <p class="font-semibold text-foreground truncate"><%= d.title %></p>
              <a href="<%= d.file_path %>" target="_blank" class="text-[10px] text-primary underline">Lihat Berkas</a>
            </li>
          <% }) %>
        <% } %>
      </ul>
    </div>

    <!-- Outcome Reports -->
    <% if (travel.status === 'completed') { %>
      <div data-slot="card" class="rounded-xl border bg-card text-card-foreground shadow-xs p-6 border-primary/40">
        <h3 class="font-semibold text-lg mb-4 border-b pb-2 text-primary">Laporan Hasil</h3>
        <div class="space-y-3">
          <div>
            <p class="text-xs font-semibold text-muted-foreground">Hasil Perjalanan (Outcome):</p>
            <p class="text-xs text-foreground bg-muted/30 p-2 rounded mt-1 whitespace-pre-line"><%= travel.travel_outcome %></p>
          </div>
          <div>
            <p class="text-xs font-semibold text-muted-foreground">Rencana Tindak Lanjut:</p>
            <p class="text-xs text-foreground bg-muted/30 p-2 rounded mt-1 whitespace-pre-line"><%= travel.outcome_followup %></p>
          </div>
        </div>
      </div>
    <% } %>

    <!-- History / Logs of approvals -->
    <div data-slot="card" class="rounded-xl border bg-card text-card-foreground shadow-xs p-6">
      <h3 class="font-semibold text-lg mb-4 border-b pb-2">Riwayat Log Approval</h3>
      <div class="space-y-4">
        <% if (approvals.length === 0) { %>
          <p class="text-xs text-muted-foreground text-center py-2">Belum ada riwayat approval.</p>
        <% } else { %>
          <% approvals.forEach(a => { %>
            <div class="border-l-2 border-primary/30 pl-3 space-y-1">
              <div class="flex items-center justify-between">
                <span class="text-xs font-semibold uppercase badge-<%= a.status %> rounded px-1.5 py-0.2 text-[9px]"><%= a.status %></span>
                <span class="text-[10px] text-muted-foreground"><%= new Date(a.action_date).toLocaleDateString('id-ID') %></span>
              </div>
              <p class="text-xs">Oleh: <strong><%= a.approver_username %></strong></p>
              <% if (a.notes) { %>
                <p class="text-xs text-muted-foreground bg-muted/40 p-1.5 rounded italic">"<%= a.notes %>"</p>
              <% } %>
            </div>
          <% }) %>
        <% } %>
      </div>
    </div>

  </div>

</div>

<%- include('../layouts/footer') %>
